        getAnalysisData: () => {
            const { policies, financials } = db.getUserData();
            const lifestyle = financials.lifestyle || {};
            const f = (val) => parseFloat(val) || 0;

            const totalLiabilities = financials.liabilities.reduce((s, i) => s + f(i.value), 0);
            const totalGoals = financials.goals.reduce((s, i) => s + f(i.value), 0);
            
            const preRetSupport = f(lifestyle.preRetExp) * 12 * f(lifestyle.preRetYears);
            const postRetSupport = f(lifestyle.postRetExp) * 12 * f(lifestyle.postRetYears);
            const totalLifestyleSupport = preRetSupport + postRetSupport;
            
            const totalRequirement = totalLiabilities + totalGoals + totalLifestyleSupport;
            const existingPolicyCover = policies.reduce((s, p) => s + f(p.sumAssured), 0);
            
            const liquidAssets = financials.assets.map(asset => {
                const adjPercent = f(asset.adjustment) || 100;
                const adjustedValue = f(asset.value) * (adjPercent / 100);
                return { ...asset, adjustedValue };
            });

            const totalLiquidAssets = liquidAssets.reduce((s, asset) => s + asset.adjustedValue, 0);
            const totalExistingCoverage = existingPolicyCover + totalLiquidAssets;
            const gap = totalRequirement - totalExistingCoverage;

            return {
                policies, financials, lifestyle, totalLiabilities, totalGoals, preRetSupport, postRetSupport,
                totalLifestyleSupport, totalRequirement, existingPolicyCover, liquidAssets, totalLiquidAssets,
