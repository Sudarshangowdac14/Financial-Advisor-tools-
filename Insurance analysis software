        },
        getAnalysisResults: (policy) => {
            const f = (val) => parseFloat(val) || 0;
            const i = (val) => parseInt(val) || 0;
            let results = {};
            let cashflows;

            try {
                if (policy.type === 'JeevanAnand') {
                    const maturityValue = f(policy.maturityValueInput);
                    const annualPremium = f(policy.annualPremium);
                    const totalYears = i(policy.totalYears), premiumPayingTerm = i(policy.premiumPayingTerm);
                    if (annualPremium <= 0 || totalYears <= 0 || premiumPayingTerm <= 0 || premiumPayingTerm > totalYears) return null;
                    cashflows = new Array(totalYears).fill(0);
                    for (let j = 0; j < premiumPayingTerm; j++) { cashflows[j] = -annualPremium; }
                    if (totalYears > 0) { cashflows[totalYears - 1] += maturityValue; }
                    results.policyDetails = { annualPremium, totalYears, payouts: [], maturityValue, premiumPayingTerm };
                } else if (policy.type === 'Endowment') {
                    const maturityValue = f(policy.maturityValueInput), vestedBonus = f(policy.vestedBonus);
                    const annualPremium = f(policy.annualPremium), totalYears = i(policy.totalYears);
                    if (annualPremium <= 0 || totalYears <= 0) return null;
                    const totalFinalPayout = maturityValue + vestedBonus;
                    cashflows = new Array(totalYears).fill(-annualPremium);
                    if (totalYears > 0) { cashflows[totalYears - 1] += totalFinalPayout; }
                    results.policyDetails = { annualPremium, totalYears, payouts: [], maturityValue: totalFinalPayout };
                } else if (policy.type === 'MoneyBack') {
                    const maturityValue = f(policy.maturityValueInput), vestedBonus = f(policy.vestedBonus);
                    const annualPremium = f(policy.annualPremium), totalYears = i(policy.totalYears);
                    if (annualPremium <= 0 || totalYears <= 0) return null;
                    const payouts = (policy.payouts || []).map(p => ({ amount: f(p.amount), year: i(p.year) }));
                    const totalFinalPayout = maturityValue + vestedBonus;
                    cashflows = new Array(totalYears).fill(-annualPremium);
                    payouts.forEach(p => { if (p.year > 0 && p.year <= totalYears) cashflows[p.year - 1] += p.amount; });
                    if (totalYears > 0) { cashflows[totalYears - 1] += totalFinalPayout; }
                    results.policyDetails = { annualPremium, totalYears, payouts, maturityValue: totalFinalPayout };
                } else if (policy.type === 'Pension') {
                    const maturityValue = f(policy.maturityValueInput), vestedBonus = f(policy.vestedBonus);
                    const annualPremium = f(policy.annualPremium), premiumYears = i(policy.premiumYears);
                    const annualPayout = f(policy.annualPayout), payoutYears = i(policy.payoutYears);
                    if (annualPremium <= 0 || premiumYears <= 0) return null;
                    const totalYears = premiumYears + payoutYears;
                    const totalFinalPayout = maturityValue + vestedBonus;
                    cashflows = new Array(totalYears).fill(0);
                    for (let j = 0; j < premiumYears; j++) cashflows[j] = -annualPremium;
                    for (let j = 0; j < payoutYears; j++) cashflows[premiumYears + j] = annualPayout;
                    if (totalYears > 0) { cashflows[totalYears - 1] += totalFinalPayout; }
                    results.policyDetails = { annualPremium, premiumYears, annualPayout, payoutYears, maturityValue: totalFinalPayout };
                }
                
                results.cashflows = cashflows;
                const accruedBonuses = f(policy.accruedBonuses), svFactor = f(policy.svFactor), premiumsPaid = i(policy.premiumsPaid);
                const annualPremium = f(policy.annualPremium), sumAssured = f(policy.sumAssured);
                const term = i(policy.totalYears) || i(policy.premiumPayingTerm) || i(policy.premiumYears) || 0;
                
                const context = { SA: sumAssured, AP: annualPremium, TY: term, PPT: term, PP: premiumsPaid };
                results.paidUpValue = policyAnalyzer.calculatePaidUpValue(policy.paidUpMethod, policy.paidUpFormula, context);
                Object.assign(context, { PUV: results.paidUpValue, AB: accruedBonuses, TPP: annualPremium * premiumsPaid, SVF: svFactor / 100 });
                results.surrenderValue = policyAnalyzer.calculateSurrenderValue(policy.surrenderMethod, policy.surrenderFormula, context);
                
                results.irr = policyAnalyzer.calculateIRR(cashflows);
                results.totalPremiumsPaid = cashflows.filter(c => c < 0).reduce((sum, c) => sum - c, 0);
                results.totalPayout = cashflows.filter(c => c > 0).reduce((sum, c) => sum + c, 0);
                results.netBenefit = results.totalPayout - results.totalPremiumsPaid;
                results.premiumsAlreadyPaidValue = annualPremium * premiumsPaid;
                results.remainingYears = term - premiumsPaid;
                
                return results;
            } catch (e) {
                console.error("Error calculating policy analysis:", e);
                return null;
            }
        },
        calculatePaidUpValue: (method, formula, context) => {
            if (method === 'custom') return policyAnalyzer.evaluateFormula(formula, context);
            const term = context.TY || context.PPT || 0;
            return term > 0 ? (context.PP / term) * context.SA : 0;
        },
        calculateSurrenderValue: (method, formula, context) => {
             if (method === 'custom') return policyAnalyzer.evaluateFormula(formula, context);
            return (context.PUV + context.AB) * context.SVF;
        },
        processAndDisplayResults: (prefix, results) => {
            const resultsContainer = document.querySelector(`#policy-detail-pane .results-section`);
            if (!resultsContainer) return;
            resultsContainer.style.display = 'block';

            document.getElementById(`${prefix}-totalPremiumsPaid`).textContent = policyAnalyzer.formatCurrency(results.totalPremiumsPaid);
            document.getElementById(`${prefix}-premiumsAlreadyPaid`).textContent = policyAnalyzer.formatCurrency(results.premiumsAlreadyPaidValue);
            document.getElementById(`${prefix}-maturityDisplay`).textContent = policyAnalyzer.formatCurrency(results.totalPayout);
            document.getElementById(`${prefix}-irrValue`).textContent = results.irr !== null ? results.irr.toFixed(2) + '%' : 'N/A';
            document.getElementById(`${prefix}-paidUpValueDisplay`).textContent = policyAnalyzer.formatCurrency(results.paidUpValue);
            document.getElementById(`${prefix}-surrenderValueDisplay`).textContent = policyAnalyzer.formatCurrency(results.surrenderValue);
            document.getElementById(`${prefix}-policySuggestion`).innerHTML = policyAnalyzer.generatePolicySuggestion(results.irr, results.netBenefit, results.remainingYears).replace(/\n/g, '<br>');

            const netBenefitElement = document.getElementById(`${prefix}-netBenefitDisplay`);
            if (netBenefitElement) {
                netBenefitElement.textContent = policyAnalyzer.formatCurrency(results.netBenefit);
                netBenefitElement.className = 'result-value';
                netBenefitElement.classList.add(results.netBenefit >= 0 ? 'positive' : 'negative');
            }

            policyAnalyzer.updateTable(prefix, results.cashflows, results.policyDetails);
            policyAnalyzer.updateCharts(prefix, results.cashflows, results.totalPremiumsPaid, results.netBenefit);
        },
        getTableData: (cashflows, details) => {
            const data = [];
            let cumulativeCashflow = 0;
            const isPension = !!details.premiumYears;
            const headers = isPension 
                ? ["Year", "Premium Outflow", "Pension Inflow", "Maturity Value", "Net Cashflow", "Cumulative Cashflow"]
                : ["Year", "Premium Outflow", "Survival/Interim Benefit", "Maturity Value", "Net Cashflow", "Cumulative Cashflow"];
            data.push(headers.map(h => ({v: h, s: { font: { bold: true }}})));

            const totalYears = cashflows.length;
            for (let i = 0; i < totalYears; i++) {
                const year = i + 1;
                const netCashflow = cashflows[i] || 0;
                cumulativeCashflow += netCashflow;
                
                let excelRow = [
                    year, 
                    {t:'n', v:0, z:'₹#,##0'}, 
                    {t:'n', v:0, z:'₹#,##0'}, 
                    {t:'n', v:0, z:'₹#,##0'}, 
                    {t:'n', v:netCashflow, z:'₹#,##0'}, 
                    {t:'n', v:cumulativeCashflow, z:'₹#,##0'}
                ];

                if (isPension) {
                    if (year <= details.premiumYears) excelRow[1].v = details.annualPremium;
                    if (year > details.premiumYears) excelRow[2].v = details.annualPayout;
                    if (year === totalYears) excelRow[3].v = details.maturityValue;
                } else {
                    const premiumTerm = details.premiumPayingTerm || details.totalYears;
                    if(year <= premiumTerm) excelRow[1].v = details.annualPremium;
                    const moneyBackPayout = (details.payouts || []).find(p => p.year == year);
                    if (moneyBackPayout) excelRow[2].v = moneyBackPayout.amount;
                    if (year === details.totalYears) excelRow[3].v = details.maturityValue;
                }
                data.push(excelRow);
            }
            return data;
        },
        updateTable: (prefix, cashflows, details) => {
            const table = document.querySelector(`#${prefix}-yearlyDataTable`);
            if(!table) return;
            const data = policyAnalyzer.getTableData(cashflows, details);
            const headers = data.shift(); // remove headers from data
            let tableHTML = `<thead><tr>${headers.map(h => `<th>${h.v}</th>`).join('')}</tr></thead><tbody>`;

            data.forEach(excelRow => {
                 tableHTML += `<tr>
                    <td>${excelRow[0]}</td>
                    <td class="negative">${excelRow[1].v > 0 ? policyAnalyzer.formatCurrency(excelRow[1].v) : '-'}</td>
                    <td class="positive">${excelRow[2].v > 0 ? policyAnalyzer.formatCurrency(excelRow[2].v) : '-'}</td>
                    <td class="positive">${excelRow[3].v > 0 ? policyAnalyzer.formatCurrency(excelRow[3].v) : '-'}</td>
                    <td class="${excelRow[4].v < 0 ? 'negative' : 'positive'}">${policyAnalyzer.formatCurrency(excelRow[4].v)}</td>
                    <td class="${excelRow[5].v < 0 ? 'negative' : 'positive'}">${policyAnalyzer.formatCurrency(excelRow[5].v)}</td>
                </tr>`;
            });
            table.innerHTML = tableHTML + '</tbody>';
        },
        updateCharts: (prefix, cashflows, totalPremiumsPaid, netGain) => {
            if (policyAnalyzer.charts[prefix]) {
                if(policyAnalyzer.charts[prefix].cashflow) policyAnalyzer.charts[prefix].cashflow.destroy();
                if(policyAnalyzer.charts[prefix].breakdown) policyAnalyzer.charts[prefix].breakdown.destroy();
            }
            const cashflowCtx = document.getElementById(`${prefix}-cashflowChart`);
            const breakdownCtx = document.getElementById(`${prefix}-breakdownChart`);
            if (!cashflowCtx || !breakdownCtx) return;

            let cumulative = 0;
            const cumulativeData = cashflows.map(cf => cumulative += (cf || 0));
            const netGainForChart = netGain > 0 ? netGain : 0;

            policyAnalyzer.charts[prefix] = {
                cashflow: new Chart(cashflowCtx, { 
                    type: 'line', 
                    data: { 
                        labels: Array.from({ length: cashflows.length }, (_, i) => `Yr ${i + 1}`),
                        datasets: [{ label: 'Cumulative Cashflow', data: cumulativeData, borderColor: '#667eea', backgroundColor: 'rgba(102,126,234,0.1)', fill: true }] 
                    }, 
                    options: { plugins: { title: { display: true, text: 'Policy Cashflows' } } } 
                }),
                breakdown: new Chart(breakdownCtx, { 
                    type: 'doughnut', 
                    data: { 
                        labels: ['Total Premiums Paid', 'Net Gain'], 
                        datasets: [{ data: [totalPremiumsPaid, netGainForChart], backgroundColor: ['#FF6384', '#36A2EB'] }] 
                    }, 
                    options: { plugins: { title: { display: true, text: 'Premiums vs. Gain' }, tooltip: { callbacks: { label: c => `${c.label}: ${policyAnalyzer.formatCurrency(c.parsed)}` }} } } 
                })
            };
        },
        calculateIRR: (cashflows) => {
            if (!cashflows || cashflows.length === 0 || cashflows.every(cf => cf <= 0) || cashflows.every(cf => cf >= 0)) return null;
            try {
                let lower = -0.9999, upper = 10, tol = 1e-7, maxIter = 1000;
                const npv = (rate) => cashflows.reduce((sum, cf, t) => sum + cf / Math.pow(1 + rate, t + 1), 0);
                let mid, value, npvLower = npv(lower);
                for (let i = 0; i < maxIter; i++) {
                    mid = (lower + upper) / 2;
                    if(mid === lower || mid === upper) break; 
                    value = npv(mid);
                    if (Math.abs(value) < tol) return mid * 100;
                    if (npvLower * value < 0) { upper = mid; } else { lower = mid; npvLower = value; }
                }
                return mid * 100;
            } catch (e) { return null; }
        },
        generatePolicySuggestion: (irr, netGain, remainingYears) => {
            let s = "";
            if (irr === null) {
                s = "IRR could not be calculated. This may be due to no positive cashflows (payouts).";
            } else {
                const irrText = `An IRR of ${irr.toFixed(2)}% is considered `;
                if (irr >= 6) s = `🟢 Strong. ${irrText} excellent.`;
                else if (irr >= 4) s = `🟡 Moderate. ${irrText} acceptable.`;
                else s = `🔴 Weak. ${irrText} low.`;
            }
            s += `\nOverall, you will ${netGain >= 0 ? 'gain' : 'lose'} ${policyAnalyzer.formatCurrency(Math.abs(netGain))} over the term.`
            if (irr !== null && remainingYears >= 0) {
                if (irr >= 6 && remainingYears <= 5) {
                    s += `\n\n<b>Recommendation:</b> With a strong IRR and only ${remainingYears} years remaining, it is <b>highly recommended to continue this policy</b>.`;
                } else if (irr < 4 && remainingYears > 10) {
                    s += `\n\n<b>Recommendation:</b> Given the low IRR and a long tenure of ${remainingYears} years remaining, you may want to <b>consider surrendering this policy</b> and evaluating alternative investment options.`;
                } else {
                    s += `\n\n<b>Recommendation:</b> The policy performance is moderate. Continue monitoring it against your financial goals.`;
                }
            }
            return s;
        },
        evaluateFormula: (formula, context) => {
            try {
                if (!formula.trim()) return 0;
                return math.evaluate(formula, context);
            } catch (e) {
                alert(`Invalid Formula:\n${e.message}\nPlease check syntax and variable names.`);
                return null;
            }
        },
        formatCurrency: (amount) => '₹' + new Intl.NumberFormat('en-IN', { maximumFractionDigits: 0 }).format(amount),
        toggleMethodInputs: (prefix, valueType) => {
            const selectedMethod = document.getElementById(`${prefix}-${valueType}Method`).value;
            ['custom', 'standard'].forEach(method => {
                const container = document.getElementById(`${prefix}-${valueType}${method.charAt(0).toUpperCase() + method.slice(1)}Container`);
                if (container) container.style.display = selectedMethod === method ? 'block' : 'none';
            });
        },
        initDefaults: (prefix) => {
            policyAnalyzer.toggleMethodInputs(prefix, 'paidUp');
            policyAnalyzer.toggleMethodInputs(prefix, 'surrender');
        }
    };

    document.addEventListener('DOMContentLoaded', app.init);
</script>
</body>
